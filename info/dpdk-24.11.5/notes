tar xf ../tarballs/dpdk-24.11.5.tar.xz
apt install meson ninja-build libnuma-dev python3-pyelftools libpcap-dev libxdp-dev libbpf-dev libssl-dev



-Ddisable_drivers=net/mlx5,net/mlx4,common/mlx5,common/mlx4

meson setup -Ddisable_drivers=net/mlx5,net/mlx4,common/mlx5,common/mlx4 build --prefix=/grid/dpdk/installed 
	(add --wipe for fresh configure)
ninja -C build
cd build
meson install
